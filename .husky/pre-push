#!/usr/bin/env sh
set -eu

if [ "${TTSMM_SKIP_PRE_PUSH:-}" = "1" ]; then
	echo "Skipping pre-push verification because TTSMM_SKIP_PRE_PUSH=1."
	exit 0
fi

should_verify=0
while read -r _local_ref _local_sha remote_ref _remote_sha; do
	if [ "$remote_ref" = "refs/heads/main" ]; then
		should_verify=1
	fi
done

if [ "$should_verify" = "0" ]; then
	exit 0
fi

CI=true pnpm run verify:push
