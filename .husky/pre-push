#!/usr/bin/env sh
set -eu

should_verify=0
while read -r _local_ref _local_sha remote_ref _remote_sha; do
	if [ "$remote_ref" = "refs/heads/main" ]; then
		should_verify=1
	fi
done

if [ "$should_verify" = "0" ]; then
	exit 0
fi

if [ "${TTSMM_PRE_PUSH_VALIDATE:-0}" != "1" ]; then
	echo "Skipping local main validation. Set TTSMM_PRE_PUSH_VALIDATE=1 to run pnpm run validate before pushing."
	exit 0
fi

CI=true pnpm run validate
