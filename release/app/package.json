{
  "name": "terratech-steam-mod-manager-ex",
  "packageManager": "pnpm@11.0.6",
  "productName": "TTSMM-EX",
  "description": "Mod loader for TerraTech that handles Steam Workshop mod configurations",
  "version": "2.1.0",
  "main": "./dist/main/main.js",
  "author": {
    "name": "Hellfrosted",
    "email": "68215103+Hellfrosted@users.noreply.github.com",
    "url": "https://github.com/Hellfrosted/terratech-steam-mod-loader"
  },
  "scripts": {
    "rebuild:electron": "node --import=tsx ../../scripts/electron-rebuild.ts",
    "link:modules": "node --import=tsx ../../scripts/link-modules.ts",
    "postinstall": "pnpm run rebuild:electron && pnpm run link:modules"
  },
  "license": "MIT",
  "dependencies": {
    "greenworks": "github:FLSoz/greenworks",
    "ps-list": "^9.0.0"
  }
}
