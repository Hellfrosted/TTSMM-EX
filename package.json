{
	"name": "terratech-steam-mod-manager-ex",
	"main": "./release/app/dist/main/main.js",
	"productName": "TerraTech Steam Mod Manager EX",
	"description": "Mod loader for TerraTech that handles Steam Workshop mod configurations",
	"version": "2.0.2",
	"scripts": {
		"dev": "node --import=tsx ./scripts/check-port-in-use.ts && electron-vite dev",
		"start:desktop": "npm run build && cross-env NODE_ENV=production electron .",
		"build": "electron-vite build",
		"postinstall": "node --import=tsx ./scripts/postinstall.ts",
		"setup:steamworks": "node --import=tsx ./scripts/setup-steamworks.ts",
		"lint": "cross-env NODE_ENV=development eslint . --ext .js,.jsx,.ts,.tsx",
		"lint:fix": "npm run lint -- --fix",
		"package": "node --import=tsx ./scripts/package.ts",
		"package:linux": "node --import=tsx ./scripts/package.ts --platform linux",
		"rebuild": "electron-rebuild --parallel --types prod,dev,optional --module-dir release/app",
		"smoke:steamworks": "node --import=tsx ./scripts/smoke-steamworks.ts",
		"test": "vitest run",
		"typecheck": "tsc -b",
		"validate": "npm run lint && npm run typecheck && npm test && npm run build",
		"publish": "node --import=tsx ./scripts/package.ts --publish onTagOrDraft",
		"bump": "node --import=tsx ./scripts/version.ts"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"cross-env NODE_ENV=development eslint --cache --fix"
		],
		"{*.json,.babelrc,.eslintrc,.prettierrc}": [
			"prettier --ignore-path .prettierignore --parser json --write"
		],
		"*.{css,scss}": [
			"prettier --ignore-path .prettierignore --single-quote --write"
		],
		"*.{html,md,yml}": [
			"prettier --ignore-path .prettierignore --single-quote --write"
		]
	},
	"build": {
		"productName": "TerraTech Steam Mod Manager EX",
		"appId": "com.hellfrosted.ttsmmex",
		"afterPack": "./scripts/after-pack-set-win-icon.cjs",
		"asar": true,
		"asarUnpack": "**/*.{node,dll,so,dylib}",
		"files": [
			"dist",
			"node_modules",
			"package.json"
		],
		"win": {
			"signAndEditExecutable": false,
			"icon": "assets/icon.ico",
			"target": [
				"nsis"
			]
		},
		"nsis": {
			"shortcutName": "TerraTech Steam Mod Manager EX",
			"uninstallDisplayName": "TerraTech Steam Mod Manager EX",
			"installerIcon": "assets/icon.ico",
			"uninstallerIcon": "assets/icon.ico",
			"installerHeaderIcon": "assets/icon.ico"
		},
		"linux": {
			"icon": "assets/icon.png",
			"target": [
				"AppImage"
			],
			"category": "Development"
		},
		"pacman": {
			"depends": [
				"alsa-lib",
				"at-spi2-core",
				"gtk3",
				"libappindicator",
				"libnotify",
				"libsecret",
				"libxss",
				"libxtst",
				"nss",
				"xdg-utils"
			]
		},
		"directories": {
			"app": "release/app",
			"buildResources": "assets",
			"output": "release/build"
		},
		"extraFiles": [
			"./steam_appid.txt"
		],
		"extraResources": [
			"./assets/**"
		],
		"publish": {
			"provider": "github",
			"owner": "Hellfrosted",
			"repo": "terratech-steam-mod-loader"
		}
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Hellfrosted/terratech-steam-mod-loader.git"
	},
	"author": {
		"name": "Hellfrosted",
		"email": "68215103+Hellfrosted@users.noreply.github.com"
	},
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/Hellfrosted/terratech-steam-mod-loader/issues"
	},
	"keywords": [
		"electron",
		"react",
		"typescript",
		"ts",
		"sass",
		"webpack",
		"hot",
		"reload",
		"terratech",
		"steam",
		"workshop",
		"mods",
		"mod manager"
	],
	"homepage": "https://github.com/Hellfrosted/terratech-steam-mod-loader#readme",
	"devDependencies": {
		"@electron/rebuild": "^4.0.3",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/dateformat": "^5.0.3",
		"@types/node": "^25.5.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.58.1",
		"@typescript-eslint/parser": "^8.58.1",
		"@vitejs/plugin-react": "^5.0.4",
		"async": ">=3.2.6",
		"chalk": "^5.6.2",
		"cross-env": "^10.1.0",
		"detect-port": "^2.1.0",
		"electron": "^41.2.0",
		"electron-builder": "^26.8.1",
		"electron-devtools-installer": "^4.0.0",
		"electron-vite": "^4.0.0",
		"eslint": "^9.39.4",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-compat": "^7.0.1",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-promise": "^7.2.1",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"husky": "^9.1.7",
		"jsdom": "^29.0.2",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"sass": "^1.99.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vite": "^7.1.12",
		"vitest": "^4.1.3"
	},
	"dependencies": {
		"@ant-design/icons": "^6.1.1",
		"@fontsource/roboto": "^5.2.10",
		"antd": "^6.3.5",
		"async-mutex": "^0.5.0",
		"axios": "^1.14.0",
		"dateformat": "^5.0.3",
		"electron-debug": "^4.1.0",
		"electron-log": "^5.4.3",
		"electron-updater": "^6.8.3",
		"less": "^4.6.4",
		"node-html-parser": "^7.1.0",
		"open": "^11.0.0",
		"ps-list": "^9.0.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-loading": "^2.0.3",
		"react-router-dom": "^7.14.0"
	},
	"engines": {
		"node": ">=20 <26",
		"npm": ">=10 <12"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=20 <26",
			"onFail": "error"
		},
		"packageManager": {
			"name": "npm",
			"version": ">=10 <12",
			"onFail": "error"
		}
	},
	"browserslist": [],
	"prettier": {
		"overrides": [
			{
				"files": [
					".prettierrc",
					".eslintrc"
				],
				"options": {
					"parser": "json",
					"trailingComma": "none",
					"useTabs": true
				}
			}
		],
		"singleQuote": true,
		"trailingComma": "none",
		"tabWidth": 2,
		"useTabs": true,
		"printWidth": 140,
		"bracketSameLine": false
	},
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged"
		}
	}
}
