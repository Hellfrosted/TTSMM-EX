{
	"name": "terratech-steam-mod-manager-ex",
	"main": "./release/app/dist/main/main.js",
	"productName": "TTSMM-EX",
	"description": "Mod loader for TerraTech that handles Steam Workshop mod configurations",
	"version": "2.1.0",
	"scripts": {
		"help": "node --import=tsx ./scripts/help.ts",
		"dev": "node --import=tsx ./scripts/check-port-in-use.ts && node --import=tsx ./scripts/run-with-clean-electron-env.ts electron-vite dev",
		"start:desktop": "npm run build && cross-env NODE_ENV=production node --import=tsx ./scripts/run-with-clean-electron-env.ts electron .",
		"build": "electron-vite build",
		"postinstall": "node --import=tsx ./scripts/postinstall.ts",
		"setup:steamworks": "node --import=tsx ./scripts/setup-steamworks.ts",
		"lint": "npm run lint:biome && npm run lint:eslint",
		"lint:eslint": "cross-env NODE_ENV=development eslint . --ext .js,.jsx,.ts,.tsx",
		"lint:eslint:fix": "cross-env NODE_ENV=development eslint . --ext .js,.jsx,.ts,.tsx --fix",
		"lint:biome": "biome check .",
		"lint:biome:fix": "biome check . --write --unsafe",
		"check:biome": "biome check .",
		"lint:fix": "npm run lint:eslint:fix && npm run lint:biome:fix",
		"deadcode": "knip",
		"package": "node --import=tsx ./scripts/package.ts",
		"package:linux": "node --import=tsx ./scripts/package.ts --platform linux",
		"rebuild": "electron-rebuild --parallel --types prod,dev,optional --module-dir release/app",
		"smoke:steamworks": "node --import=tsx ./scripts/smoke-steamworks.ts",
		"test": "vitest run",
		"typecheck": "tsc -b",
		"validate": "npm run lint && npm run deadcode && npm run typecheck && npm test && npm run build",
		"publish": "node --import=tsx ./scripts/package.ts --publish onTagOrDraft",
		"bump": "node --import=tsx ./scripts/version.ts"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"biome check --write --unsafe --no-errors-on-unmatched",
			"cross-env NODE_ENV=development eslint --cache --fix"
		],
		"*.{json,jsonc}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"build": {
		"productName": "TTSMM-EX",
		"appId": "com.hellfrosted.ttsmmex",
		"afterPack": "./scripts/after-pack-set-win-icon.cjs",
		"asar": true,
		"asarUnpack": "**/*.{node,dll,so,dylib}",
		"files": [
			"dist",
			"node_modules",
			"package.json"
		],
		"win": {
			"signAndEditExecutable": false,
			"icon": "assets/icon.ico",
			"target": [
				"nsis"
			]
		},
		"nsis": {
			"shortcutName": "TTSMM-EX",
			"uninstallDisplayName": "TTSMM-EX",
			"installerIcon": "assets/icon.ico",
			"uninstallerIcon": "assets/icon.ico",
			"installerHeaderIcon": "assets/icon.ico"
		},
		"linux": {
			"icon": "assets/icon.png",
			"target": [
				"AppImage"
			],
			"category": "Development"
		},
		"pacman": {
			"depends": [
				"alsa-lib",
				"at-spi2-core",
				"gtk3",
				"libappindicator",
				"libnotify",
				"libsecret",
				"libxss",
				"libxtst",
				"nss",
				"xdg-utils"
			]
		},
		"directories": {
			"app": "release/app",
			"buildResources": "assets",
			"output": "release/build"
		},
		"extraFiles": [
			"./steam_appid.txt"
		],
		"extraResources": [
			"./assets/**"
		],
		"publish": {
			"provider": "github",
			"owner": "Hellfrosted",
			"repo": "terratech-steam-mod-loader"
		}
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Hellfrosted/terratech-steam-mod-loader.git"
	},
	"author": {
		"name": "Hellfrosted",
		"email": "68215103+Hellfrosted@users.noreply.github.com"
	},
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/Hellfrosted/terratech-steam-mod-loader/issues"
	},
	"keywords": [
		"electron",
		"react",
		"typescript",
		"ts",
		"hot",
		"reload",
		"terratech",
		"steam",
		"workshop",
		"mods",
		"mod manager"
	],
	"homepage": "https://github.com/Hellfrosted/terratech-steam-mod-loader#readme",
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@electron/rebuild": "^4.0.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/dateformat": "^5.0.3",
		"@types/node": "^24.12.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.59.0",
		"@typescript-eslint/parser": "^8.59.0",
		"@vitejs/plugin-react": "^5.2.0",
		"chalk": "^5.6.2",
		"cross-env": "^10.1.0",
		"detect-port": "^2.1.0",
		"electron": "^41.3.0",
		"electron-builder": "^26.8.1",
		"electron-devtools-installer": "^4.0.0",
		"electron-vite": "^4.0.1",
		"eslint": "^9.39.4",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-promise": "^7.2.1",
		"eslint-plugin-react-hooks": "^7.1.1",
		"globals": "^14.0.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.2",
		"knip": "^6.7.0",
		"lint-staged": "^16.4.0",
		"rimraf": "^6.1.3",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"vite": "^7.3.2",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@hookform/resolvers": "^5.2.2",
		"@tailwindcss/vite": "^4.2.4",
		"@tanstack/react-query": "^5.100.5",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.13.24",
		"async-mutex": "^0.5.0",
		"axios": "^1.15.2",
		"dateformat": "^5.0.3",
		"electron-debug": "^4.1.0",
		"electron-log": "^5.4.3",
		"electron-updater": "^6.8.3",
		"lucide-react": "^1.11.0",
		"node-html-parser": "^7.1.0",
		"ps-list": "^9.0.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-hook-form": "^7.74.0",
		"react-router-dom": "^7.14.2",
		"source-map-support": "^0.5.21",
		"tailwindcss": "^4.2.4",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"engines": {
		"node": ">=20 <26",
		"npm": ">=10 <12"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=20 <26",
			"onFail": "error"
		},
		"packageManager": {
			"name": "npm",
			"version": ">=10 <12",
			"onFail": "error"
		}
	},
	"browserslist": [],
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged"
		}
	}
}
