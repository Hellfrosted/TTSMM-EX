{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"composite": true,
		"noEmit": true,
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"types": ["vite/client"]
	},
	"include": [
		"src/renderer/**/*.ts",
		"src/renderer/**/*.tsx",
		"src/renderer/types/**/*.d.ts",
		"src/__tests__/types/**/*.d.ts",
		"src/model/**/*.ts",
		"src/shared/**/*.ts",
		"src/util/**/*.ts",
		"assets/assets.d.ts"
	]
}
