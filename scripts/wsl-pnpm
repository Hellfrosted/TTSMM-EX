#!/usr/bin/env bash
set -euo pipefail

if ! grep -qi microsoft /proc/sys/kernel/osrelease 2>/dev/null; then
	echo "scripts/wsl-pnpm is only for WSL. Use pnpm directly outside WSL." >&2
	exit 1
fi

if ! command -v wslpath >/dev/null 2>&1; then
	echo "wslpath is required to call Windows pnpm from WSL." >&2
	exit 1
fi

repo_root="$(git rev-parse --show-toplevel)"
repo_win_path="$(wslpath -w "$repo_root")"
script_win_path="$(wslpath -w "$repo_root/scripts/wsl-pnpm.ps1")"

encoded_args=""
for arg in "$@"; do
	encoded_arg="$(printf '%s' "$arg" | base64 -w 0)"
	if [[ -n "$encoded_args" ]]; then
		encoded_args+=$'\n'
	fi
	encoded_args+="$encoded_arg"
done

WSL_PNPM_WORKING_DIRECTORY="$repo_win_path" \
	WSL_PNPM_ARGS_BASE64="$encoded_args" \
	WSLENV="WSL_PNPM_WORKING_DIRECTORY:WSL_PNPM_ARGS_BASE64${WSLENV:+:$WSLENV}" \
	powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$script_win_path"
